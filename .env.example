# Yggdrasil Seedling Environment Variables
#
# Copy this file to .env at the repo root and fill in real values:
#   cp .env.example .env
#
# Then run:
#   docker compose -f infrastructure/compose.yaml \
#     -f seedlings/001-energy/config/compose.override.yaml up

# --- Required ---

# PostgreSQL password for the seedling database
POSTGRES_PASSWORD=change-me-to-a-strong-password

# GitHub auth for publisher service (PAT with repo write access)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=dschirmer-shiftkey/komatik-yggdrasil
GITHUB_BRANCH=main

# Seedling identity (override per-seedling in compose.override.yaml)
SEEDLING_NAME=Energy
SEEDLING_DIR=seedlings/001-energy

# LLM provider keys (at least one required for Bifrost)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Bifrost virtual key — used for agent auth to the LLM gateway
SEEDLING_VIRTUAL_KEY=svk-energy-001

# --- Optional ---
# GATEWAY_PORT=18789
# BIFROST_PORT=8080
# DB_PORT=5432
# CYCLE_INTERVAL_MINUTES=60
# PUBLISH_INTERVAL_MINUTES=30
