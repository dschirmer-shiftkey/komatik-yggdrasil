# Yggdrasil Seed Environment Variables
#
# Copy this file to .env at the repo root and fill in real values:
#   cp .env.example .env
#
# Then boot a seed:
#   docker compose --project-directory . -f infrastructure/compose.yaml \
#     -f seeds/001-energy/config/compose.override.yaml up
#
# Or for Homelessness LA:
#   docker compose --project-directory . -f infrastructure/compose.yaml \
#     -f seeds/002-homelessness-la/config/compose.override.yaml up

# --- Required ---

# PostgreSQL password for the seed database
POSTGRES_PASSWORD=change-me-to-a-strong-password

# GitHub auth for publisher service (PAT with repo write access)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=dschirmer-shiftkey/komatik-yggdrasil
GITHUB_BRANCH=main

# Seed identity (override per-seed in compose.override.yaml)
SEED_NAME=Energy
SEED_DIR=seeds/001-energy

# LLM provider keys (at least one required for Bifrost)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Bifrost virtual key — used for agent auth to the LLM gateway
SEED_VIRTUAL_KEY=svk-energy-001

# --- Optional ---
# GATEWAY_PORT=18789
# BIFROST_PORT=8080
# DB_PORT=5432
# CYCLE_INTERVAL_MINUTES=60
# PUBLISH_INTERVAL_MINUTES=30
