# Seedling Environment Variables
# Copy to .env and fill in real values before running docker compose up

# --- Required ---
POSTGRES_PASSWORD=change-me-to-a-strong-password

# GitHub auth for publisher service
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=dschirmer-shiftkey/komatik-yggdrasil
GITHUB_BRANCH=main

# Seedling identity
SEEDLING_NAME=Energy
SEEDLING_DIR=seedlings/001-energy

# LLM provider keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Bifrost virtual key
SEEDLING_VIRTUAL_KEY=svk-energy-001

# --- Optional ---
# GATEWAY_PORT=18789
# BIFROST_PORT=8080
# DB_PORT=5432
# CYCLE_INTERVAL_MINUTES=60
# PUBLISH_INTERVAL_MINUTES=30
