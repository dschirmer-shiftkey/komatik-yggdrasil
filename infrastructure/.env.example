# Seed Environment Variables
# Copy to .env and fill in real values before running docker compose up

# --- Required ---

# PostgreSQL password for the seed database
POSTGRES_PASSWORD=change-me-to-a-strong-password

# GitHub auth for publisher service (PAT with repo write access)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=KomatikAI/cairn
GITHUB_BRANCH=dev

# Seed identity (override per-seed in compose.override.yaml)
# Defaults below match seed 002 dry-run; change for seed 001-energy.
SEED_NAME="Homelessness LA"
SEED_DIR=seeds/002-homelessness-la

# LLM — dry-run uses OpenRouter only (see seeds/002-homelessness-la/config/dry-run/bifrost.json)
OPENROUTER_API_KEY=sk-or-xxx
# Optional for non-dry-run stacks:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Bifrost virtual key — used for agent auth to the LLM gateway
SEED_VIRTUAL_KEY=svk-energy-001

# Cairn world-tree Supabase project (NOT the Komatik platform DB)
# Project ref: aiszfddbzrhksqkaxmur (name: cairn) — apply 001_cairn_world_tree_schema.sql if greenfield
SUPABASE_URL=https://aiszfddbzrhksqkaxmur.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...or_eyJ...

# Container identity within the hierarchy
SOURCE_TYPE=seed
SOURCE_ID=002-homelessness-la
CATEGORY_ID=housing
ROOT_ID=basic-needs

# --- Optional ---
# GATEWAY_PORT=18789
# BIFROST_PORT=8080
# DB_PORT=5432
# CYCLE_INTERVAL_MINUTES=60
# PUBLISH_INTERVAL_MINUTES=30

# --- Seed 002 dry-run ---
# Publisher disabled in compose.dry-run.yaml; GITHUB_TOKEN may be empty.
# Preflight: bash infrastructure/scripts/preflight-seed-dry-run.sh
# Boot: see seeds/002-homelessness-la/config/dry-run/README.md

# --- Apex tier (Cairn HQ) ---
# APEX_CYCLE_INTERVAL_MINUTES=1440          # daily

# --- Public Signal aggregator ---
# AGGREGATION_INTERVAL_MINUTES=10080        # weekly
# MIN_SIGNALS_FOR_DIGEST=3
# MIN_HOURS_BETWEEN_DIGESTS=24
# SIGNAL_ISSUE_LABEL=public-signal
# SIGNAL_DIGEST_MODEL=claude-sonnet-4-20250514
