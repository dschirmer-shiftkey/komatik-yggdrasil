# Seed Environment Variables
# Copy to .env and fill in real values before running docker compose up

# --- Required ---

# PostgreSQL password for the seed database
POSTGRES_PASSWORD=change-me-to-a-strong-password

# GitHub auth for publisher service (PAT with repo write access)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=dschirmer-shiftkey/komatik-yggdrasil
GITHUB_BRANCH=main

# Seed identity (override per-seed in compose.override.yaml)
SEED_NAME=Energy
SEED_DIR=seeds/001-energy

# LLM provider keys (at least one required for Bifrost)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# Bifrost virtual key — used for agent auth to the LLM gateway
SEED_VIRTUAL_KEY=svk-energy-001

# World Tree — shared Supabase project for cross-tier knowledge
SUPABASE_URL=https://spsvhxldmpcdlulklqzp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Container identity within the tree hierarchy
SOURCE_TYPE=seed
SOURCE_ID=002-homelessness-la
CATEGORY_ID=housing
ROOT_ID=basic-needs

# --- Optional ---
# GATEWAY_PORT=18789
# BIFROST_PORT=8080
# DB_PORT=5432
# CYCLE_INTERVAL_MINUTES=60
# PUBLISH_INTERVAL_MINUTES=30

# --- Apex tier (Yggdrasil HQ) ---
# APEX_CYCLE_INTERVAL_MINUTES=1440          # daily

# --- Public Signal aggregator ---
# AGGREGATION_INTERVAL_MINUTES=10080        # weekly
# MIN_SIGNALS_FOR_DIGEST=3
# MIN_HOURS_BETWEEN_DIGESTS=24
# SIGNAL_ISSUE_LABEL=public-signal
# SIGNAL_DIGEST_MODEL=claude-sonnet-4-20250514
